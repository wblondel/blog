---
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import { useTranslations } from "../../i18n/utils";

interface Props {
    projects: CollectionEntry<"projects">[];
    lang: string;
}

const { projects, lang } = Astro.props;
const t = useTranslations(lang as any);
---

<section class="mt-12">
    <div class="flex items-center gap-3 mb-8">
        <div class="p-3 bg-primary/10 text-primary rounded-xl">
            <Icon name="fa6-solid:folder-open" class="w-6 h-6" />
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-foreground">{t('portfolio.projects')}</h2>
    </div>

    {projects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {projects.map((project) => (
                <div class="group relative flex flex-col bg-card border border-border rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:border-primary/50 transition-all duration-300">
                    <a href={`${import.meta.env.BASE_URL}${lang}/projects/${project.id.split('/').slice(1).join('/')}/`} aria-hidden="true" class="absolute inset-0 z-10"></a>
                    <!-- Project Image Area -->
                    <div class="relative w-full aspect-video bg-muted border-b border-border overflow-hidden">
                        {project.data.coverImage ? (
                            <img 
                                src={typeof project.data.coverImage === 'string' ? project.data.coverImage : project.data.coverImage.src} 
                                alt={project.data.title}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center text-muted-foreground/50 bg-gradient-to-br from-muted to-muted/50">
                                <Icon name="fa6-solid:image" class="w-16 h-16 opacity-30 group-hover:scale-110 transition-transform duration-500" />
                            </div>
                        )}
                        <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/10 transition-colors duration-300 pointer-events-none"></div>
                        {project.data.draft && (
                            <div class="absolute top-4 right-4 bg-destructive text-destructive-foreground text-xs font-bold px-2 py-1 rounded shadow-sm z-20">
                                DRAFT
                            </div>
                        )}
                    </div>
                    
                    <!-- Content Area -->
                    <div class="p-6 flex flex-col flex-1 h-full">
                        <div class="flex items-start justify-between gap-4 mb-4">
                            <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors">
                                {project.data.title}
                            </h3>
                        </div>
                        
                        <p class="text-muted-foreground text-sm leading-relaxed mb-6 flex-1 relative z-20">
                            {project.data.context}
                        </p>
                        
                        <div class="mt-auto pt-4 border-t border-border/50 flex flex-wrap gap-3 relative z-20">
                            {project.data.githubLink && (
                                <a 
                                    href={project.data.githubLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-primary transition-colors hover:underline"
                                >
                                    <Icon name="fa6-brands:github" class="w-4 h-4" />
                                    {t('portfolio.githubLink')}
                                </a>
                            )}
                            
                            {project.data.liveLink && (
                                <a 
                                    href={project.data.liveLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-primary transition-colors hover:underline"
                                >
                                    <Icon name="fa6-solid:link" class="w-4 h-4" />
                                    {t('portfolio.liveLink')}
                                </a>
                            )}

                            {project.data.documentationLink && (
                                <a 
                                    href={project.data.documentationLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-primary transition-colors hover:underline"
                                >
                                    <Icon name="fa6-solid:file-lines" class="w-4 h-4" />
                                    {t('portfolio.documentationLink')}
                                </a>
                            )}
                            
                            {project.data.ficheDescriptiveLink && (
                                <a 
                                    href={project.data.ficheDescriptiveLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 text-sm font-medium text-foreground hover:text-primary transition-colors hover:underline"
                                >
                                    <Icon name="fa6-solid:graduation-cap" class="w-4 h-4" />
                                    {t('portfolio.ficheDescriptiveLink')}
                                </a>
                            )}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    ) : (
        <div class="bg-card border border-border border-dashed rounded-xl p-12 flex flex-col items-center justify-center text-center max-w-2xl mx-auto">
            <Icon name="fa6-solid:folder-open" class="w-16 h-16 text-muted-foreground/30 mb-4" />
            <h3 class="text-xl font-medium text-foreground mb-2">{t('portfolio.noProjectsYet')}</h3>
            <p class="text-muted-foreground">{t('portfolio.noProjectsYetDescription')}</p>
        </div>
    )}
</section>
