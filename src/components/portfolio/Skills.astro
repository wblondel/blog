---
import { Icon } from "astro-icon/components";
import { useTranslations } from "../../i18n/utils";

interface Props {
    skills: {
        technical: string[];
        soft: string[];
    };
    certifications: any[];
    interests: string[];
    lang: string;
}

const { skills, certifications, interests, lang } = Astro.props;
const t = useTranslations(lang as any);
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-12 items-stretch">
    <!-- Skills -->
    <div class="flex flex-col h-full">
        <section class="bg-card border border-border rounded-2xl p-6 sm:p-8 shadow-sm flex-1 flex flex-col">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-3 bg-primary/10 text-primary rounded-xl">
                    <Icon name="fa6-solid:code" class="w-6 h-6" />
                </div>
                <h2 class="text-2xl font-bold text-foreground">{t('portfolio.skills')}</h2>
            </div>
            
            <div class="space-y-6">
                <div>
                    <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4">{t('portfolio.skills.technical')}</h3>
                    <div class="flex flex-wrap gap-2 sm:gap-3">
                        {skills.technical.map((skill) => (
                            <div class="group flex items-center gap-2 px-4 py-2 bg-muted/50 border border-border hover:border-primary/50 hover:bg-primary/5 rounded-lg transition-all cursor-default">
                                <Icon name="fa6-solid:check" class="w-3 h-3 text-primary opacity-50 group-hover:opacity-100 transition-opacity" />
                                <span class="text-foreground font-medium text-sm">{skill}</span>
                            </div>
                        ))}
                    </div>
                </div>
                
                <div class="pt-4 border-t border-border/50">
                    <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-4">{t('portfolio.skills.soft')}</h3>
                    <div class="flex flex-wrap gap-2 sm:gap-3">
                        {skills.soft.map((skill) => (
                            <div class="group flex items-center gap-2 px-4 py-2 bg-muted/50 border border-border hover:border-primary/50 hover:bg-primary/5 rounded-lg transition-all cursor-default">
                                <Icon name="fa6-solid:check" class="w-3 h-3 text-primary opacity-50 group-hover:opacity-100 transition-opacity" />
                                <span class="text-foreground font-medium text-sm">{skill}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    </div>

    <!-- Right Sidebar: Certifications & Interests -->
    <div class="space-y-8 flex flex-col h-full">
        <!-- Certifications -->
        <section class="bg-card border border-border rounded-2xl p-6 sm:p-8 shadow-sm flex-1">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-3 bg-primary/10 text-primary rounded-xl">
                    <Icon name="fa6-solid:certificate" class="w-6 h-6" />
                </div>
                <h2 class="text-2xl font-bold text-foreground">{t('portfolio.certifications')}</h2>
            </div>
            
            <ul class="space-y-4">
                {certifications.map((cert) => (
                    <li class="flex items-start gap-3">
                        <Icon name="fa6-solid:award" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
                        <div class="min-w-0">
                            <p class="font-medium text-foreground text-sm break-words">{cert.name}</p>
                            <p class="text-xs text-muted-foreground mt-0.5">{cert.issuer} • {cert.date}</p>
                        </div>
                    </li>
                ))}
            </ul>
        </section>

        <!-- Interests -->
        <section class="bg-card border border-border rounded-2xl p-6 sm:p-8 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-3 bg-primary/10 text-primary rounded-xl">
                    <Icon name="fa6-solid:heart" class="w-6 h-6" />
                </div>
                <h2 class="text-2xl font-bold text-foreground">{t('portfolio.interests')}</h2>
            </div>
            
            <ul class="flex flex-wrap gap-2">
                {interests.map((interest: any) => (
                    typeof interest === 'string' ? (
                        <li class="px-3 py-1.5 bg-muted text-muted-foreground text-sm rounded-full border border-border/50">
                            {interest}
                        </li>
                    ) : (
                        <li>
                            <a 
                                href={interest.url} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="inline-flex items-center px-3 py-1.5 bg-muted text-muted-foreground hover:text-primary hover:border-primary/50 hover:bg-primary/5 text-sm rounded-full border border-border/50 transition-colors"
                                title={interest.label}
                            >
                                {interest.label}
                                <Icon name="fa6-solid:arrow-up-right-from-square" class="w-3 h-3 ml-1.5 opacity-70" />
                            </a>
                        </li>
                    )
                ))}
            </ul>
        </section>
    </div>
</div>
