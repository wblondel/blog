---
import { Icon } from "astro-icon/components";
import { useTranslations } from "../../i18n/utils";

interface Props {
    experience: any[];
    education: any[];
    lang: string;
}

const { experience, education, lang } = Astro.props;
const t = useTranslations(lang as any);

const formatDate = (dateString: string) => {
    if (dateString === 'Present') return t('portfolio.present');
    
    const [year, month] = dateString.split('-');
    const date = new Date(parseInt(year), parseInt(month) - 1);
    
    return new Intl.DateTimeFormat(t('site.locale') as string, { 
        month: 'short', 
        year: 'numeric' 
    }).format(date);
};
---

<div class="grid grid-cols-1 gap-16 mt-12 max-w-5xl mx-auto">
    <!-- Experience Section -->
    <section>
        <div class="flex items-center gap-3 mb-8">
            <div class="p-3 bg-primary/10 text-primary rounded-xl">
                <Icon name="fa6-solid:briefcase" class="w-6 h-6" />
            </div>
            <h2 class="text-3xl font-bold tracking-tight text-foreground">{t('portfolio.experience')}</h2>
        </div>
        
        <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-border before:to-transparent">
            {experience.map((item, index) => (
                <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-background bg-muted text-muted-foreground shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 group-hover:bg-primary group-hover:text-primary-foreground group-hover:border-primary/20 transition-colors z-10">
                        <Icon name="fa6-solid:building" class="w-4 h-4" />
                    </div>
                    
                    <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-card border border-border p-5 rounded-xl shadow-sm hover:shadow-md transition-shadow relative">
                        <!-- Arrow pointing to the dot -->
                        <div class="absolute top-5 -left-2 md:group-even:left-auto md:group-even:-right-2 w-4 h-4 bg-card border-b border-l md:group-even:border-b-0 md:group-even:border-l-0 md:group-even:border-t md:group-even:border-r rotate-45 border-border -z-10"></div>
                        
                        <div class="flex flex-col gap-1 mb-3">
                            <h3 class="font-bold text-lg text-foreground">{item.role}</h3>
                            <div class="flex items-center justify-between flex-wrap gap-2 text-sm">
                                {item.url ? (
                                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="font-medium text-primary hover:underline inline-flex items-center gap-1 group/link">
                                        {item.company}
                                        <Icon name="fa6-solid:arrow-up-right-from-square" class="w-2.5 h-2.5 opacity-50 group-hover/link:opacity-100 transition-opacity" />
                                    </a>
                                ) : (
                                    <span class="font-medium text-primary">{item.company}</span>
                                )}
                                <span class="text-muted-foreground bg-muted px-2 py-0.5 rounded-full text-xs">
                                    {formatDate(item.startDate)} - {formatDate(item.endDate)}
                                </span>
                            </div>
                            <span class="text-xs text-muted-foreground flex items-center gap-1 mt-1">
                                <Icon name="fa6-solid:location-dot" class="w-3 h-3" />
                                {item.location}
                            </span>
                        </div>
                        <p class="text-muted-foreground text-sm leading-relaxed whitespace-pre-line">{item.description}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Education Section -->
    <section>
        <div class="flex items-center gap-3 mb-8">
            <div class="p-3 bg-primary/10 text-primary rounded-xl">
                <Icon name="fa6-solid:graduation-cap" class="w-6 h-6" />
            </div>
            <h2 class="text-3xl font-bold tracking-tight text-foreground">{t('portfolio.education')}</h2>
        </div>
        
        <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-border before:to-transparent">
            {education.map((item, index) => (
                <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                    <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-background bg-muted text-muted-foreground shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 group-hover:bg-primary group-hover:text-primary-foreground group-hover:border-primary/20 transition-colors z-10">
                        <Icon name="fa6-solid:book" class="w-4 h-4" />
                    </div>
                    
                    <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-card border border-border p-5 rounded-xl shadow-sm hover:shadow-md transition-shadow relative">
                        <!-- Arrow pointing to the dot -->
                        <div class="absolute top-5 -left-2 md:group-even:left-auto md:group-even:-right-2 w-4 h-4 bg-card border-b border-l md:group-even:border-b-0 md:group-even:border-l-0 md:group-even:border-t md:group-even:border-r rotate-45 border-border -z-10"></div>
                        
                        <div class="flex flex-col gap-1 mb-3">
                            <h3 class="font-bold text-lg text-foreground leading-tight mb-1">{item.degree}</h3>
                            <div class="flex items-center justify-between flex-wrap gap-2 text-sm">
                                {item.url ? (
                                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="font-medium text-primary hover:underline inline-flex items-center gap-1 group/link">
                                        {item.institution}
                                        <Icon name="fa6-solid:arrow-up-right-from-square" class="w-2.5 h-2.5 opacity-50 group-hover/link:opacity-100 transition-opacity" />
                                    </a>
                                ) : (
                                    <span class="font-medium text-primary">{item.institution}</span>
                                )}
                                <span class="text-muted-foreground bg-muted px-2 py-0.5 rounded-full text-xs">
                                    {formatDate(item.startDate)} - {formatDate(item.endDate)}
                                </span>
                            </div>
                            <span class="text-xs text-muted-foreground flex items-center gap-1 mt-1">
                                <Icon name="fa6-solid:location-dot" class="w-3 h-3" />
                                {item.location}
                            </span>
                        </div>
                        <p class="text-muted-foreground text-sm leading-relaxed whitespace-pre-line">{item.description}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>
</div>
